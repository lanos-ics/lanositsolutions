generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Blog {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  category   String
  excerpt    String
  content    String   @db.Text
  coverImage String
  author     Json
  featured   Boolean  @default(false)
  tags       String[]
  keywords   String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  comments Comment[]
  likes    Like[]

  @@index([category])
  @@index([featured])
}

model Comment {
  id        String   @id @default(cuid())
  blogId    String
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  name      String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([blogId])
}

model Like {
  blogId    String
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  sessionId String
  createdAt DateTime @default(now())

  @@id([blogId, sessionId])
  @@index([blogId])
}

model Track {
  slug         String   @id
  label        String
  description  String   @db.Text
  accent       String
  accentBg     String
  accentBorder String
  accentGlow   String
  emoji        String
  comingSoon   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  courses Course[]
}

model Course {
  trackSlug        String
  track            Track    @relation(fields: [trackSlug], references: [slug], onDelete: Cascade)
  slug             String
  title            String
  description      String   @db.Text
  briefDescription String?  @db.Text
  icon             String
  originalPrice    Int
  price            Int
  syllabusUrl      String
  badge            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@id([trackSlug, slug])
  @@index([trackSlug])
}
